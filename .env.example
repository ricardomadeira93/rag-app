# ENV
APP_ENV=development

# BACKEND
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# FRONTEND
CORS_ORIGINS=
NEXT_PUBLIC_API_URL=

# OLLAMA (IMPORTANT)
OLLAMA_BASE_URL=
OLLAMA_KEEP_ALIVE=5m

# MODELS
OLLAMA_LLM=llama3.1:8b
OLLAMA_EMBED=nomic-embed-text

# AUDIO
DEFAULT_WHISPER_MODEL=base
# If your docs are English-only and you want the lightest dev setup:
# DEFAULT_WHISPER_MODEL=tiny.en

# STORAGE
DATA_PATH=/data

# CLOUD AI (Optional: for production deployment)
GROQ_API_KEY=
PINECONE_API_KEY=
